#!/bin/bash
# Scrabble launch script

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR" || exit 1

# Compile/package without tests
mvn -q -DskipTests package
if [ $? -ne 0 ]; then
    echo "Erreur : Echec du build sans tests." >&2
    exit 1
fi

# Cherche le fichier .jar dans le dossier target/
JAR_FILE=$(find target -maxdepth 1 -name "*.jar" ! -name "original-*.jar" | head -n 1)

if [ -z "$JAR_FILE" ]; then
    echo "Erreur : Aucun fichier JAR trouvé dans le dossier 'target/'." >&2
    echo "Veuillez d'abord compiler le projet avec 'mvn package'." >&2
    exit 1
fi

# Lance l'application
exec java -jar "$JAR_FILE" "$@"